VITE_PRIVY_APP_ID=your_privy_app_id
VITE_SQUADS_VAULT=
VITE_SOLANA_RPC=https://api.devnet.solana.com

# Agent wallet for swap execution. Generate with: npm run generate:agent
# AGENT_KEYPAIR="[1,2,3,...]"  # 64 numbers, JSON array

# Squads multi-sig (human-in-the-loop). When set, propose-swap creates Squads proposals.
# SQUADS_MULTISIG_PDA=   # Multisig PDA address
# SQUADS_VAULT_INDEX=0   # Vault index (default 0)
# SQUADS_CREATE_KEY="[1,2,3,...]"  # Keypair of a multisig member (JSON array, 64 numbers)

DEEPSEEK_API_KEY=your_deepseek_api_key
JUPITER_API_KEY=your_jupiter_api_key
KYC_WHITELIST=
